# ── 選擇 AI 提供者：claude 或 ollama ──────────────────────
LLM_PROVIDER=claude

# ── Claude (Anthropic) ─────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here
MODEL_ID=claude-sonnet-4-6

# ── Ollama（本地）─────────────────────────────────────────
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5:14b   # 推薦：qwen2.5、llama3.1、gemma3
#
# 本地開發（ai-service 直接跑）：
# OLLAMA_BASE_URL=http://localhost:11434
#
# Docker Compose 內訪問宿主機 Ollama：
# OLLAMA_BASE_URL=http://host.docker.internal:11434   # Mac / Windows
# OLLAMA_BASE_URL=http://172.17.0.1:11434             # Linux
